@model KP_Eventify.Models.Event

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

@if (TempData["ErrorMessage"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="card">
    <div class="card-body">
        <h3>@Model.Name</h3>
        <p>@Model.Description</p>
        <p><strong>Дата:</strong> @Model.Date.ToString("dd.MM.yyyy HH:mm")</p>
        <p><strong>Цена:</strong> @Model.Price.ToString("F2") лв.</p>
        <p><strong>Налични билети:</strong> @Model.AvailableTickets</p>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <form asp-controller="Tickets" asp-action="Buy" method="post">
                <input type="hidden" name="eventId" value="@Model.Id" />
                <button type="submit" class="btn btn-success" @(Model.AvailableTickets == 0 ? "disabled" : null)>Купи билет</button>
            </form>
        }
        else
        {
            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary">Влезте, за да купите билет</a>
        }
    </div>
</div>

<p class="mt-3"><a asp-action="Index">Назад към събитията</a></p>